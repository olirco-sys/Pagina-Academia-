      --verde:#7bb342;
      --amarillo:#ffd166;
      --rojo:#ef233c;
    }

    body{
      font-family:'Segoe UI', Arial, sans-serif;
      color:#17324a;
      background:#fff;
      padding-bottom:90px;
    }

    .navbar{
      background:linear-gradient(90deg,var(--azul-oscuro),var(--azul-medio));
    }

    .urgency-strip{
      background:#ef233c;
      color:white;
      font-weight:900;
      padding:.75rem;
      text-align:center;
      margin-top:56px;
    }

    .discount-hero{
      min-height:100vh;
      padding-top:70px;
      color:white;
      background:
        radial-gradient(circle at top left,rgba(255,209,102,.45),transparent 28%),
        radial-gradient(circle at bottom right,rgba(191,238,250,.55),transparent 30%),
        linear-gradient(135deg,#061d41,#08295c,#0077a8);
    }

    .big-banner{
      background:linear-gradient(90deg,var(--rojo),#ff7b00,var(--amarillo));
      color:#111;
      border-radius:26px;
      padding:1.3rem;
      font-weight:1000;
      text-align:center;
      box-shadow:0 18px 45px rgba(0,0,0,.28);
      font-size:1.35rem;
    }

    .discount-box{
      background:white;
      color:var(--azul-oscuro);
      border-radius:36px;
      padding:2rem;
      box-shadow:0 30px 70px rgba(0,0,0,.35);
      border:5px solid rgba(255,209,102,.9);
    }

    .discount-number{
      font-size:6rem;
      line-height:.9;
      font-weight:1000;
      background:linear-gradient(135deg,#08295c,#0077a8,#22a447);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .timer-panel{
      background:#061d41;
      color:white;
      border-radius:26px;
      padding:1.4rem;
      border:3px solid var(--amarillo);
      box-shadow:0 18px 45px rgba(0,0,0,.25);
    }

    .timer-number{
      font-size:4.2rem;
      font-weight:1000;
      letter-spacing:2px;
      color:#ffd166;
    }

    .btn-whatsapp{
      background:linear-gradient(90deg,#7bb342,#9bd45c);
      color:white!important;
      font-weight:800;
      border:none;
      border-radius:50px;
      padding:.9rem 1.5rem;
      box-shadow:0 10px 24px rgba(0,0,0,.18);
    }

    .btn-whatsapp:hover{
      transform:translateY(-2px);
    }

    .pulse{
      animation:pulse 1.4s infinite;
    }

    @keyframes pulse{
      0%{transform:scale(1)}
      50%{transform:scale(1.035)}
      100%{transform:scale(1)}
    }

    .section-title{
      color:var(--azul-oscuro);
      font-weight:900;
    }

    .course-card{
      border:0;
      border-radius:24px;
      padding:1.5rem;
      height:100%;
      background:white;
      box-shadow:0 12px 28px rgba(8,41,92,.12);
      transition:.3s;
    }

    .course-card:hover{
      transform:translateY(-6px);
    }

    .badge-area{
      background:rgba(0,119,168,.1);
      color:var(--azul-oscuro);
      border:1px solid rgba(0,119,168,.25);
    }

    .price{
      color:var(--azul-oscuro);
      font-weight:900;
      font-size:1.1rem;
    }

    .gradient-section{
      background:linear-gradient(135deg,#f7fbff,#eaf8fc);
    }

    .sticky-cta{
      position:fixed;
      left:0;
      right:0;
      bottom:0;
      z-index:998;
      background:linear-gradient(90deg,#061d41,#0077a8);
      color:white;
      padding:.75rem 1rem;
      box-shadow:0 -10px 25px rgba(0,0,0,.25);
    }

    .floating-whatsapp{
      position:fixed;
      right:22px;
      bottom:95px;
      background:#25d366;
      color:white!important;
      width:62px;
      height:62px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:2rem;
      box-shadow:0 10px 25px rgba(0,0,0,.25);
      z-index:999;
      text-decoration:none;
    }

    .footer{
      background:#061d41;
      color:white;
    }

    @media(max-width:768px){
      .discount-number{
        font-size:4.4rem;
      }

      .timer-number{
        font-size:3rem;
      }

      .big-banner{
        font-size:1.05rem;
      }
    }
  </style>
</head>

